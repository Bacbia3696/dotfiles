! URxvt config
URxvt.font: xft:SauceCodePro Nerd Font Mono:style=Semibold:size=13:minsize=False, xft:Dejavu Sans:style=Medium:size=11,xft:Symbola,xft:Noto Emoji:minspace=False
URxvt.boldFont: xft:SauceCodePro Nerd Font Mono:style=Black:size=13:minsize=False, xft:Dejavu Sans:style=Bold:size=11,xft:Symbola,xft:Noto Emoji:minspace=False
/* URxvt.font: xft:SauceCodePro Nerd Font Mono:style=Semibold:size=13:minsize=False, xft:Dejavu Sans:style=Medium:size=11 */
/* URxvt.boldFont: xft:SauceCodePro Nerd Font Mono:style=Black:size=13:minsize=False, xft:Dejavu Sans:style=Bold:size=11 */


URxvt.scrollBar: false
URxvt.secondaryScreen: 1
URxvt.secondaryScroll: 0

! Key Bindings
! ============

! Copy/Paste, same keys as gnome-terminal
! Disable ISO 14755 unicode input so we can use Ctrl-Shift bindings
URxvt.iso14755:        false
URxvt.iso14755_52:     false
URxvt.keysym.Control-Shift-C: eval:selection_to_clipboard
URxvt.keysym.Control-Shift-V: eval:paste_clipboard

! scale fonts
URxvt.perl-ext-common: default,resize-font

! Dracula theme
*.foreground:     #F8F8F2
*.background:     #282A36
*.color0:         #000000
*.color8:         #4D4D4D
*.color1:         #FF5555
*.color9:         #FF6E67
*.color2:         #50FA7B
*.color10:        #5AF78E
*.color3:         #F1FA8C
*.color11:        #F4F99D
*.color4:         #BD93F9
*.color12:        #CAA9FA
*.color5:         #FF79C6
*.color13:        #FF92D0
*.color6:         #8BE9FD
*.color14:        #9AEDFE
*.color7:         #BFBFBF
*.color15:        #E6E6E6
