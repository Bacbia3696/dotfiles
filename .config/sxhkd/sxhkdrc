##################
# Focus and move #
##################
# Focus or swap window in the current workspace
super + {_,ctrl + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}
# Focus the given workspace or move window to that workspace
super + {_,shift + }{1-9,0}
	bspc {desktop -f, node -d} '^{1-9,10}'
# Focus the next/previous workspace or window
{super,alt} + {_,shift + }grave
	bspc {desktop,node} -f {next,prev}.local
# Focus the last workspace or window
super + Tab
	bspc desktop -f last
# Preselect the direction
super + shift + {h,j,k,l}
	bspc node -p {west,south,north,east}
# Cancel the preselection for the focused desktop
super + Escape
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel
# Move to next and previous window
super + {Next,Prior}
    bspc desktop -f {next,prev}
# Circulate focused locally
alt + {_,shift} + Tab
    bspc node -f {next.local,prev.local}
# Select all windows
super + a
    bspc node -f @/
#
# resize tiled/floating
#

# expand the tiled space in the given direction
super + alt + {h,j,k,l}
	bspc node {@west -r -10,@south -r +10,@north -r -10,@east -r +10}

# contract the tiled space in the given direction
super + alt + shift + {h,j,k,l}
	bspc node {@east -r -10,@north -r +10,@south -r -10,@west -r +10}

# # move a floating window
# super + {Left,Down,Up,Right}
# 	xdo move {-x -20,-y +20,-y -20,-x +20}

# # expand the floating space in the given direction
# super + alt + {Left,Down,Up,Right}
# 	xdo resize {-w -20,-h +20,-h -20,-w +20}

super + {Left,Right}
    bspc node @/ -R {-90,90}

##################
# Window control #
##################
# Close or kill window
super + {_,shift + } q
	bspc node -{c,k}
# Toggle floating state
super + ctrl + f
    if [ -z "$(bspc query -N -n focused.floating)" ]; then \                    
        bspc node focused -t floating; \                                        
    else \                                                                      
        bspc node focused -t tiled; \                                           
    fi
# Toggle sticky flag
super + ctrl + s
	bspc node -g sticky
# Win+M : Toggle tiled/monocle
super + m
	bspc desktop -l next

# Win+F : Toggle fullscreen active window
super + f
	bspc node focused -t '~fullscreen'

# Win+G : Move active window to biggest space
super + g
	bspc node -s biggest

###########
# Session #
###########
# Lock screen
super + x
    i3lock-next
# Power menu
super + shift + p
    $HOME/.config/dmenu/scripts/dmenu-power
# Quit bspwm
super + ctrl + q
    bspc quit
# Reload bspwm and sxhkd
super + ctrl + r
    pkill -USR1 -x sxhkd && bspc wm -r

##############
# Media keys #
##############
# Volume
{XF86AudioMute,XF86AudioLowerVolume,XF86AudioRaiseVolume}
	amixer -q set Master {toggle,5%- unmute,5%+ unmute}
# Player
{XF86AudioPrev,XF86AudioPlay,XF86AudioNext}
	playerctl {previous,play-pause,next}
# Brightness
{XF86MonBrightnessDown,XF86MonBrightnessUp}
	xbacklight {-,+}10
# Screenshot
{_,ctrl + ,alt + }Print
    maim {_,-s,-i $(xdotool getactivewindow)} --noopengl | \
    xclip -selection clipboard -t image/png -i
shift + Print
    maim -s --noopengl ~/Pictures/Screenshots/$(date +%s).png

################
# Quick launch #
################
# Run command
super + space
    dmenu_run -nb "#282A36" \
              -nf "#F8F8F2" \
              -sb "#BD93F9" \
              -sf "#282A36" \
              -fn "Mono-12.5" \
              -p  "Run"
# Terminal
super + Return
	urxvt
# Web browser
super + {_,shift + }w
    google-chrome-stable {_,--app=https://youtube.com} --force-device-scale-factor=1.15
# File manager
super + shift + f
    pcmanfm
# Document viewer
super + d
    zathura
# Virtual machine manager
super + v
    virt-manager
# Translator
super + {_,shift +}t
    $HOME/.config/dmenu/scripts/dmenu-trans {en:vi,_}
# Calculator
super + c
    $HOME/.config/dmenu/scripts/dmenu-calc
# Network menu
super + n
    $HOME/.config/dmenu/scripts/dmenu-wifi
# Key bindings list
super + slash
    $HOME/.config/dmenu/scripts/dmenu-help
# # Ranger: file manager
# super + r
#     urxvt -e ranger
# Toggle mpd
super + p
    ~/.config/scripts/mpd-toggle.sh
super + period
    mpc next
super + comma
    mpc prev

